# Modul 3, Layer 1 - Claude generates the layout directives (the "AI in the loop").
# Without a key the pipeline falls back to a deterministic heuristic (flagged).
ANTHROPIC_API_KEY=

# Optional GPU panoptic reconstruction (Modul 2) - off by default.
ENABLE_EPRECON=false
USE_GPU=false
EPRECON_ENDPOINT=
