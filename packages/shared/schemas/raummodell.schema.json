{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "raummodell.schema.json",
  "title": "Raummodell",
  "description": "Vertrag 1: Output Raum-Engine → Input Solver/Viewer. y-up, rechtshändig, Meter; Grundriss in der x/z-Ebene. Quelle: Brain → Domaenenmodell-Schema-Spezifikation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "name",
    "roomType",
    "source",
    "units",
    "shell",
    "openings",
    "zones",
    "fixpoints",
    "objects",
    "meta"
  ],
  "properties": {
    "id": { "$ref": "#/$defs/uuid" },
    "schemaVersion": { "$ref": "#/$defs/semver" },
    "name": { "type": "string", "minLength": 1 },
    "roomType": { "$ref": "#/$defs/roomType" },
    "source": { "enum": ["scan", "video", "plan-import", "sample", "manuell"] },
    "units": { "const": "m" },
    "shell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["walls", "floor", "ceiling"],
      "properties": {
        "walls": {
          "description": "Wand-SEGMENTE (kein Polygon): nur Segmente tragen kind massiv/offen/virtuell je Kante (Grossraum). Validator: Hülle geschlossen.",
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "start", "end", "height", "thickness", "kind"],
            "properties": {
              "id": { "$ref": "#/$defs/uuid" },
              "start": { "$ref": "#/$defs/vec2" },
              "end": { "$ref": "#/$defs/vec2" },
              "height": { "type": "number", "exclusiveMinimum": 0 },
              "thickness": { "type": "number", "minimum": 0 },
              "kind": { "enum": ["massiv", "offen", "virtuell"] },
              "openings": { "type": "array", "items": { "$ref": "#/$defs/uuid" } }
            }
          }
        },
        "floor": {
          "description": "Wird aus den Wand-Segmenten ABGELEITET/validiert, nicht doppelt gepflegt.",
          "type": "object",
          "additionalProperties": false,
          "required": ["polygon"],
          "properties": {
            "polygon": { "type": "array", "minItems": 3, "items": { "$ref": "#/$defs/vec2" } },
            "area": { "type": "number", "minimum": 0 }
          }
        },
        "ceiling": {
          "type": "object",
          "additionalProperties": false,
          "required": ["height"],
          "properties": { "height": { "type": "number", "exclusiveMinimum": 0 } }
        }
      }
    },
    "openings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "hostWall", "offset", "width", "height", "sill"],
        "properties": {
          "id": { "$ref": "#/$defs/uuid" },
          "type": { "enum": ["door", "window"] },
          "hostWall": { "$ref": "#/$defs/uuid" },
          "offset": {
            "type": "number",
            "minimum": 0,
            "description": "Abstand des Öffnungs-Anfangs vom Wand-Start entlang der Wand (m)."
          },
          "width": { "type": "number", "exclusiveMinimum": 0 },
          "height": { "type": "number", "exclusiveMinimum": 0 },
          "sill": { "type": "number", "minimum": 0, "description": "Brüstungshöhe; Türen: 0." }
        }
      }
    },
    "zones": {
      "description": "Funktionsbereiche innerhalb einer Hülle (Grossraum). Regeln gelten pro Zone.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "roomType", "polygon"],
        "properties": {
          "id": { "$ref": "#/$defs/uuid" },
          "name": { "type": "string" },
          "roomType": { "$ref": "#/$defs/roomType" },
          "polygon": { "type": "array", "minItems": 3, "items": { "$ref": "#/$defs/vec2" } }
        }
      }
    },
    "fixpoints": {
      "description": "Anschlüsse – die Brücke zu den harten connection-Regeln. Standort genügt.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "position", "mount", "origin"],
        "properties": {
          "id": { "$ref": "#/$defs/uuid" },
          "type": { "$ref": "#/$defs/anschlussTyp" },
          "position": { "$ref": "#/$defs/vec2" },
          "wall": { "$ref": "#/$defs/uuid" },
          "heightFromFloor": { "type": "number", "minimum": 0 },
          "mount": { "enum": ["wand", "boden"] },
          "origin": { "enum": ["bestand", "vorwand", "manuell"] },
          "zone": { "oneOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }] }
        }
      }
    },
    "objects": {
      "description": "Erkannte Bestandsobjekte (für Umbau ggf. entfernen/behalten).",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "geometry", "pose", "movable", "confidence"],
        "properties": {
          "id": { "$ref": "#/$defs/uuid" },
          "label": { "type": "string", "minLength": 1 },
          "geometry": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repr", "bbox"],
            "properties": {
              "repr": { "enum": ["bbox", "mesh-simpl", "voxel"] },
              "bbox": { "$ref": "#/$defs/masse" },
              "meshRef": { "type": "string" }
            }
          },
          "pose": { "$ref": "#/$defs/pose" },
          "movable": { "type": "boolean" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "needsReview": { "type": "boolean" }
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["captureMethod", "estimatedError_cm", "geometryConfirmed"],
      "properties": {
        "captureMethod": { "enum": ["ar", "sfm", "plan", "sample", "manuell"] },
        "coverageScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "estimatedError_cm": { "type": "number", "minimum": 0 },
        "geometryConfirmed": {
          "type": "boolean",
          "description": "Nutzer hat Masse bestätigt → Unsicherheits-Marge der Konfidenz-Ampel wird 0."
        },
        "geometryRef": { "type": "string" }
      }
    }
  },
  "$defs": {
    "uuid": { "type": "string", "format": "uuid" },
    "semver": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "vec2": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2,
      "description": "[x, z] in Metern (Grundriss-Ebene)."
    },
    "pose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pos", "yawDeg"],
      "properties": {
        "pos": { "$ref": "#/$defs/vec2" },
        "yawDeg": { "type": "number", "description": "Rotation um y in Grad (POC: 2D-Top-Down)." }
      }
    },
    "masse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["w", "d", "h"],
      "properties": {
        "w": { "type": "number", "exclusiveMinimum": 0 },
        "d": { "type": "number", "exclusiveMinimum": 0 },
        "h": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "roomType": { "enum": ["bad", "kueche", "wohnen", "schlafen", "essen", "flur", "sonstig"] },
    "anschlussTyp": {
      "enum": ["wasser", "abwasser", "elektro", "starkstrom", "lueftung", "heizung"]
    }
  }
}
