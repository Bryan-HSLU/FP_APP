{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taxonomie.schema.json",
  "title": "Taxonomie",
  "description": "Stützschema (Stammdaten): datengetriebenes Achsen-Set (ADR-0006) + offenes Attribut-Vokabular. Erweiterung der Achsen/Attribute braucht KEINE Schema-Änderung – nur eine neue Taxonomie-Version.",
  "type": "object",
  "additionalProperties": false,
  "required": ["taxonomyVersion", "achsen", "attributKategorien"],
  "properties": {
    "taxonomyVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "achsen": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "negativPol", "positivPol"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "negativPol": { "type": "string", "minLength": 1, "description": "Bedeutung bei −1." },
          "positivPol": { "type": "string", "minLength": 1, "description": "Bedeutung bei +1." },
          "beschreibung": { "type": "string" }
        }
      }
    },
    "attributKategorien": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "beschreibung": { "type": "string" },
          "werte": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
            "description": "Optional: bekannte Werte; offenes Vokabular, neue Werte erlaubt."
          }
        }
      }
    }
  }
}
