  },
  "dependencies": {
    "@fp/shared": "workspace:*",
    "@react-three/fiber": "9.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.184.0",
    "@react-three/drei": "10.7.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "5.1.4",
    "typescript": "5.9.3",
    "vite": "7.3.5",
    "vitest": "4.1.8"
  }
}
